# ─── Backend .env ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values

PORT=5000
FRONTEND_URL=http://localhost:3000

# IPFS via Pinata (get free key at pinata.cloud)
# Leave blank to use local IPFS daemon (run `ipfs daemon`)
PINATA_API_KEY=
PINATA_SECRET=

IPFS_GATEWAY=https://ipfs.io/ipfs/

# AES-256 master secret — CHANGE THIS in production!
ENCRYPTION_MASTER_SECRET=ehr_iilm_secret_change_in_production
